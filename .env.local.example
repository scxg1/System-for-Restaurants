# =====================================================
# The Foodie Wagon — Environment Variables
# Copy this file to .env.local and fill in your values
# =====================================================

# --- Supabase (database + auth + realtime) ---
# Get from: https://supabase.com -> Your Project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Cloudinary (image uploads) ---
# Get from: https://cloudinary.com -> Dashboard
# You must create an UNSIGNED upload preset:
#   Settings -> Upload -> Add upload preset -> Signing Mode: Unsigned -> Save
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
